# TOWER Umar Strategy Lab — Environment Variables
# Copy this file to apps/web/.env.local (for the dashboard)
# and optionally to .env in the repo root (for the Python engine).

# ── NT8 File Storage ─────────────────────────────────────────────────────────
# Absolute path to the local folder where uploaded .cs files are stored.
# The folder will be created automatically if it does not exist.
TOWER_UPLOADED_INDICATORS_DIR=

# ── MBO Data ─────────────────────────────────────────────────────────────────
# Absolute path to the local SSD directory containing Databento NQ MBO files
# (.dbn / .dbn.zst). Used by the Python engine in Phase 4+.
TOWER_MBO_DATA_DIR=

# ── Databento ─────────────────────────────────────────────────────────────────
# Databento API key — for live catalog/metadata queries in Phase 4+.
# Not required for local-file-only backtesting.
DATABENTO_API_KEY=

# ── Python ────────────────────────────────────────────────────────────────────
# Python binary used by the Next.js API to run the engine scripts.
# Default: python3. Override if you use a venv or specific Python path.
TOWER_PYTHON_BIN=python3
